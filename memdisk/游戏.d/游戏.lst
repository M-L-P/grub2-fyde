###############################################################################
#                                 [游戏.lst]
#                             to load Flappy Bird
###############################################################################

#==============================================================================
#####----{配置}----
#------------------------------------------------------------------------------
menu_config
#==============================================================================

#==============================================================================
#####----{功能}----
#------------------------------------------------------------------------------
function load_game {
	linux16 ${game_dir}/内存设备 raw
	initrd16 ${game_dir}/飞扬的小鸟.img
}
#------------------------------------------------------------------------------
function bios_video {
	insmod fixvideo
	fix_video
	loadbios ${game_dir}/seabios.bin
}
#------------------------------------------------------------------------------
function add_item {
	menuentry "$1" "$2" --class "关于/游戏" {
		$2
		load_game
	}
}
#==============================================================================

#==============================================================================
#####----{条目}----
#------------------------------------------------------------------------------
add_parent
#------------------------------------------------------------------------------
add_item $"Flappy Bird" ""
#------------------------------------------------------------------------------
add_item $"Flappy Bird"" (bios dump)" "loadbios ${game_dir}/seabios.bin"
#------------------------------------------------------------------------------
add_item $"Flappy Bird"" (bios & fix_video)" "bios_video"
#------------------------------------------------------------------------------
add_item $"Flappy Bird"" (fakebios)" "fakebios"
#==============================================================================