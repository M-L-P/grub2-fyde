#==============================================================================
#####----{еЉџиѓЅ}----
#------------------------------------------------------------------------------
function echo_img {
	echo -e "\n	IMG_FILE=${IMG_FILE}\n	FILE_NAME=${FILE_NAME}\n	IMG_DIR=${IMG_DIR}\n	IMG_PART=${IMG_PART}\n";
};
#------------------------------------------------------------------------------
function echo_var {
	echo -e "\n	IMG_PATH=${IMG_PATH}\n	UUID_filesystem=${UUID_filesystem}\n	UUID_partition=${UUID_partition}\n";
};
#==============================================================================
if [ "е®‰иЈ…" == "${menu_id}" ]; then
#==============================================================================
#####----{е®‰иЈ…}----
#------------------------------------------------------------------------------
### иЏњеЌ•
	menu_config; if [ "ж–‡д»¶" == "${selected}" ]; then background_color "black"; fi;
#------------------------------------------------------------------------------
### жќЎз›®
	add_parent;
	add_submenu $"Files: "${FILE_NAME}	"е®‰иЈ…/ж–‡д»¶"	"f"	"ж–‡д»¶";
	if [ "ејЂ" != "${gear_mount}" ]; then
		menuentry $"Mount" --class "е®‰иЈ…/жЊ‚иЅЅ" {
			regexp --set=1:IMG_PATH '^.*\)(.*$)' "${IMG_FILE}";
			regexp --set=1:IMG_PART '(^\(.*[,].*\))/.*' "${IMG_FILE}"; loopback -d loop;
			if loopback loop ${IMG_FILE}; then probe --set=UUID_filesystem -u ${IMG_PART};
				probe --set=UUID_partition -g (loop,gpt3); export gear_mount=ејЂ IMG_NAME=${FILE_NAME};
			else false; fi; configfile ${config_file};
		};
	elif [ "ејЂ" == "${gear_mount}" ]; then
		menuentry $"Unmount: "${IMG_NAME} --class "е®‰иЈ…/еЌёиЅЅ" {
			loopback -d loop; gear_mount=е…і; configfile ${config_file};
		};
		menuentry $"Boot: "${IMG_NAME} --class "е®‰иЈ…/еђЇеЉЁ" {
			echo -e " "$"Show information related to image files: "; echo_img;
			echo -e " "$"Show the passed variables: "; echo_var;
			echo -e "\n\n\n\n\n\n\n	"$"No (press [ESC] or [F4])""			"$"Yes (waiting for the countdown to end)""\n\n\n\n\n"
			if sleep -v -i 30; then
				linux (loop,gpt12)/syslinux/vmlinuz.A init=/sbin/init rootwait ro \
				noresume loglevel=7 audit=0 console=  i915.modeset=1 cros_efi \
				root=PARTUUID=${UUID_partition} \
				img_path=${IMG_PATH} filesystem_UUID=${UUID_filesystem};
				initrd ${experimental_dir}/virtual_usb.cpio;
			else false; fi;
		}; fi;
#==============================================================================
elif [ "ж–‡д»¶" == "${menu_id}" ]; then
#==============================================================================
#####----{ж–‡д»¶}----
#------------------------------------------------------------------------------
	source ${menu_dir}/ж–‡д»¶.lst
#==============================================================================
fi;