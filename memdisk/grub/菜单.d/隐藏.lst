#==============================================================================
#####----{功能}----
#------------------------------------------------------------------------------
function restore_default {
	echo -e "\n\n\n\n\n\n\n	"$"You are going to lose your current settings!!!""\n	\n\n\n\n\n\n\n	"$"No (press [ESC] or [F4])""			"$"Yes (waiting for the countdown to end)""\n\n\n\n\n";
	if sleep -v -i 15; then disable_USB; disable_PS2;
	for key_name in ${grubenv_variables};do ini_get --set=${key_name} ${menu_dir}/重置.ini 默认:${key_name}; done;
	export lang=""; save_grubenv ${grubenv_variables}; clear_menu; normal;
	else false; fi;
};
#------------------------------------------------------------------------------
function menu_echo {
	menuentry "$1" "$2" --class "启事/$2" {
		clear_menu; menu_echo "点返回啊！" "流泪"; menuentry "返回" --class "启事/返回" {
			clear_menu; menuentry "不听劝告，返回键失灵了吧？" --class "启事/流泪" {
				menuentry "再按一次" --class "启事/流泪" {clear_menu; menu_echo "应该修好了！" "流泪"; submenu_back;};
			};
		};
	};
};
#------------------------------------------------------------------------------
function soon_late {
	menuentry $"Coming Soon or Late!" --class "启事/进展中" {
		clear_menu; menu_echo "别点啦！" "流泪"; menu_echo "没有就是没有！" "流泪"; 
		menu_echo "点返回啊！" "流泪"; menu_echo "急用就去相关圈子找大佬" "红包"; menu_echo "打赏一下帮你编译" "红包"; 
	};
};
#------------------------------------------------------------------------------
function show_ppt {
	export theme=${prefix}/主题/su/$1.txt;
};
#------------------------------------------------------------------------------
function turn_home {
	menuentry "home" --hotkey "esc" {normal;};
};
#------------------------------------------------------------------------------
function turn_forword {
	hiddenentry "$1" "$2" "$3" "$4" "$5" --hotkey "tab" {
		clear_menu; show_ppt "$1"; turn_home; 
		if [ "丙" != "$1" ]; then turn_forword "$2" "$3" "$4" "$5" "$1"; fi; 
		if [ "总" != "$1" ]; then turn_backword "$5" "$4" "$3" "$2" "$1"; fi;
	};
};
#------------------------------------------------------------------------------
function turn_backword {
	hiddenentry "$1" "$2" "$3" "$4" "$5" --hotkey "backspace" {
		clear_menu; show_ppt "$1"; turn_home; 
		if [ "丙" != "$1" ]; then turn_forword "$5" "$4" "$3" "$2" "$1"; fi; 
		if [ "总" != "$1" ]; then turn_backword "$2" "$3" "$4" "$5" "$1"; fi;
	};
};
#------------------------------------------------------------------------------
function add_item {
	menuentry "$1" "$2" "$3" "$4" "$5" "$6" "$7" --class "隐藏/$2" --id "$2" {
		shift 2
		clear_menu; show_ppt "$1"; turn_home; 
		if [ "丙" != "$1" ]; then turn_forword "$2" "$3" "$4" "$5" "$1"; fi;
		if [ "总" != "$1" ]; then turn_backword "$5" "$4" "$3" "$2" "$1"; fi;
	};
};
#------------------------------------------------------------------------------
function Kernel_SU {
	add_item "Readme" "幻灯片" "甲" "乙" "丙" "" "总"
	menuentry "Kernel SU(experimental)" --class "隐藏/KSU" {
		clear_menu; set initrd=${experimental_dir}/KernelSU/initrd_ksu_fydeos.cpio
		if [ -s "${initrd}" ]; then
			menuentry "initrd_ksu_fydeos.cpio" --class "隐藏/KSU" {
				clear_menu; submenu_back; soon_late; loop_img; 
				if [ "${vmlinuz_A}" -nt "${vmlinuz_B}" ]; then vmlinuz=${vmlinuz_A}; 
				else set vmlinuz=${vmlinuz_B}; fi; linux_kernel; initrd ${initrd};
			};
		else submenu_back; soon_late; fi;
	};
};
#------------------------------------------------------------------------------
function add_menu {
	menuentry "$1" "$2" "$3" "$4" --class "$2" --id "$3" {$4;};
};
#==============================================================================

#==============================================================================
#####----{条件}----
#------------------------------------------------------------------------------
if [ "倒计时" == "${thatthat}" ]; then background_image; refresh_theme;
elif [ "语言" == "${thatthat}" ]; then refresh_theme; fi;
#==============================================================================
if [ "隐藏" == "${menu_id}" ]; then
#==============================================================================
#####----{隐藏}----
#------------------------------------------------------------------------------
### 配置
	menu_config "${selected_hidden}" "前";
#------------------------------------------------------------------------------
### 条目
	add_parent;
	add_submenu $"Boot menu" "隐藏/捂脸" "h" "启动";
	add_menu $"Terminal" "隐藏/终端" "终端" "commandline";
	add_submenu $"Root permission" "隐藏/su" "s" "Root";
	add_menu $"Reset" "隐藏/重置" "重置" "restore_default";
#==============================================================================
elif [ "启动" == "${menu_id}" ]; then
#==============================================================================
#####----{启动}----
#------------------------------------------------------------------------------
### 配置
	menu_config "${selected_hidden}" "前";
#------------------------------------------------------------------------------
### 条目
	add_parent; multiboot_A; multiboot_B; recovery_tools;
	add_submenu $"Slot: [${SLOT}]" "启动/槽位" "s" "槽位";
	add_submenu $"Install fydeOS" "启动/U盘" "i" "安装";
#==============================================================================
elif [ "Root" == "${menu_id}" ]; then
#==============================================================================
#####----{Root}----
#------------------------------------------------------------------------------
### 配置
	menu_config "${selected_hidden}" "前";
#------------------------------------------------------------------------------
### 条目
	add_parent; add_item "Root readme" "幻灯片" "总" "甲" "乙" "丙" "";
	submenu "Kernel SU" --class "隐藏/KSU" --hotkey "insert" {Kernel_SU;};
	submenu "APatch" --class "隐藏/AP" {
		add_item "Readme" "幻灯片" "乙" "丙" "" "总" "甲";
		menuentry "APatch(experimental)" --class "隐藏/AP" {
			clear_menu; for fydeos_branch in classic slim iris apu; do
				set vmlinuz=${experimental_dir}/APatch/kernel_apatch_fydeos_${fydeos_branch};
				if [ -s "${vmlinuz}" ]; then
					menuentry "kernel_apatch_fydeos_${fydeos_branch}" --class "隐藏/AP" {clear_menu; submenu_back; soon_late; loop_img; boot_fydeos;};
				fi; done; submenu_back; soon_late;
		};
	};
#==============================================================================
elif [ "槽位" == "${menu_id}" ]; then
#==============================================================================
#####----{槽位}----
#------------------------------------------------------------------------------
### 配置
	menu_config "${number_slot}" "前"; default_number=${number_slot}; ini_option;
#------------------------------------------------------------------------------
### 条目
	add_parent; add_selection $"Turn A" "A" "A"; add_selection $"Turn B" "B" "B";
#==============================================================================
fi