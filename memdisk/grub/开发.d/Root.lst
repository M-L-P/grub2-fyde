#==============================================================================
#####----{功能}----
#------------------------------------------------------------------------------
function menu_echo {
	menuentry "$1" "$2" --class "启事/$2" {
		clear_menu; menu_echo "点返回啊！" "流泪"; menuentry "返回" --class "启事/返回" {
			clear_menu; menuentry "不听劝告，返回键失灵了吧？" --class "启事/流泪" {
				menuentry "再按一次" --class "启事/流泪" {clear_menu; menu_echo "应该修好了！" "流泪"; submenu_back;};
			};
		};
	};
};
#------------------------------------------------------------------------------
function soon_late {
	menuentry $"Coming Soon or Late!" --class "启事/进展" {
		clear_menu; menu_echo "别点啦！" "流泪"; menu_echo "没有就是没有！" "流泪"; 
		menu_echo "点返回啊！" "流泪"; menu_echo "急用就去相关圈子找大佬" "红包"; menu_echo "打赏一下帮你编译" "红包"; 
	};
};
#------------------------------------------------------------------------------
function show_ppt {
	export theme=${dir_themes}/su.gtpk/$1.txt;
};
#------------------------------------------------------------------------------
function turn_home {
	menuentry "home" --hotkey "esc" {normal;};
};
#------------------------------------------------------------------------------
function turn_forword {
	hiddenentry "$1" "$2" "$3" "$4" "$5" --hotkey "tab" {
		clear_menu; show_ppt "$1"; turn_home; 
		if [ "丙" != "$1" ]; then turn_forword "$2" "$3" "$4" "$5" "$1"; fi; 
		if [ "总" != "$1" ]; then turn_backword "$5" "$4" "$3" "$2" "$1"; fi;
	};
};
#------------------------------------------------------------------------------
function turn_backword {
	hiddenentry "$1" "$2" "$3" "$4" "$5" --hotkey "backspace" {
		clear_menu; show_ppt "$1"; turn_home; 
		if [ "丙" != "$1" ]; then turn_forword "$5" "$4" "$3" "$2" "$1"; fi; 
		if [ "总" != "$1" ]; then turn_backword "$2" "$3" "$4" "$5" "$1"; fi;
	};
};
#------------------------------------------------------------------------------
function add_slide {
	menuentry "$1" "$2" "$3" "$4" "$5" "$6" "$7" --class "隐藏/$2" --id "$2" {
		shift 2
		clear_menu; show_ppt "$1"; turn_home; 
		if [ "丙" != "$1" ]; then turn_forword "$2" "$3" "$4" "$5" "$1"; fi;
		if [ "总" != "$1" ]; then turn_backword "$5" "$4" "$3" "$2" "$1"; fi;
	};
};
#------------------------------------------------------------------------------
function Kernel_SU {
	add_slide "Readme" "幻灯片" "甲" "乙" "丙" "" "总"
	menuentry "Kernel SU(experimental)" --class "隐藏/KSU" {
		clear_menu; set initrd=${dir_experimental}/KernelSU/initrd_ksu_fydeos.cpio
		if [ -s "${initrd}" ]; then
			menuentry "initrd_ksu_fydeos.cpio" --class "隐藏/KSU" {
				clear_menu; submenu_back; soon_late; loop_img; 
				if [ "${vmlinuz_A}" -nt "${vmlinuz_B}" ]; then vmlinuz=${vmlinuz_A}; 
				else set vmlinuz=${vmlinuz_B}; fi;
				linux_kernel; initrd ${initrd};
			};
		else submenu_back; soon_late; fi;
	};
};
#==============================================================================

#==============================================================================
#####----{Root}----
#------------------------------------------------------------------------------
### 配置
	menu_config;
#------------------------------------------------------------------------------
### 条目
	add_parent "隐藏"; add_slide "Root readme" "幻灯片" "总" "甲" "乙" "丙" "";
	submenu "Kernel SU" --class "隐藏/KSU" --hotkey "insert" {Kernel_SU;};
	submenu "APatch" --class "隐藏/AP" {
		add_slide "Readme" "幻灯片" "乙" "丙" "" "总" "甲";
		menuentry "APatch(experimental)" --class "隐藏/AP" {
			clear_menu; for fydeos_branch in classic slim iris apu; do
				set vmlinuz=${dir_experimental}/APatch/kernel_apatch_fydeos_${fydeos_branch};
				if [ -s "${vmlinuz}" ]; then
					menuentry "kernel_apatch_fydeos_${fydeos_branch}" --class "隐藏/AP" {clear_menu; submenu_back; soon_late; loop_img; boot_fydeos;};
				fi; done; unset fydeos_branch; submenu_back; soon_late;
		};
	};
#==============================================================================