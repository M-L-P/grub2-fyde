#==============================================================================
#####----{环境变量}----
#------------------------------------------------------------------------------
function load_grubenv {
	load_env --file=${cmdpath}/grubenv;
};
#------------------------------------------------------------------------------
function save_grubenv {
	save_env --file=${cmdpath}/grubenv $@;
};
#------------------------------------------------------------------------------
function unset_variables {
	for thing in $@; do unset ${thing}; done; unset thing;
};
#------------------------------------------------------------------------------
function load_ini {
	if [ "info" == "$1" ]; then ini_file=${dir_gtpk_name}/info.ini;
	else ini_file=${dir_init}/$1.ini; fi; ini_section=$2; shift 2;
	for ini_key in $@; do
		ini_get --set=unreferenced_string ${ini_file} ${ini_section}:${ini_key};
		eval ${ini_key}="${unreferenced_string}";
	done; unset_variables ini_file ini_section ini_key unreferenced_string;
};
#==============================================================================

